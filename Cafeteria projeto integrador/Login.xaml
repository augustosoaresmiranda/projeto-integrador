<Page x:Class="Cafeteria_projeto_integrador.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Cafeteria_projeto_integrador"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid Background="#FF6F4E37">
        <Grid.RowDefinitions>
            <RowDefinition Height="122*"/>
            <RowDefinition Height="103*"/>
        </Grid.RowDefinitions>
        <TextBox  x:Name="txbUser" HorizontalAlignment="Center" Margin="0,122,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="166" Height="31" BorderBrush="White"/>
        <TextBox x:Name="txbSenha" HorizontalAlignment="Left" Margin="319,6,0,0" VerticalAlignment="Top" Width="150" Grid.Row="1"/>
        <Button x:Name="btnEntrar" Content="Logar" HorizontalAlignment="Center" VerticalAlignment="Center" Width="170" Height="50" Grid.Row="1" Background="#FFC8A96B" Foreground="White" FontSize="20"   Style="{StaticResource RoundedButtonStyle}" BorderBrush="#FF6F4E37" Click="BtnLogar"/>

    </Grid>
</Page>
