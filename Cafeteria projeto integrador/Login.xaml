<Page x:Class="Cafeteria_projeto_integrador.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Cafeteria_projeto_integrador"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid Background="#FFDB9C60">
        <Label Content="Nome" HorizontalAlignment="Left" Margin="250,88,0,0" VerticalAlignment="Top" RenderTransformOrigin="1.088,0.321"/>
        <Label Content="Senha" HorizontalAlignment="Left" Margin="250,160,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txb1" HorizontalAlignment="Center" Margin="0,92,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" TextChanged="TextBox_TextChanged"/>
        <PasswordBox HorizontalAlignment="Center" Margin="0,164,0,0" VerticalAlignment="Top" Width="120"/>
        <Button Content="Entrar" HorizontalAlignment="Center" Margin="0,277,0,0" VerticalAlignment="Top" Width="60"/>

    </Grid>
</Page>
