<Window x:Class="CoffeeGold.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coffee Gold"
        Height="820"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F6F1EB"
        ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210*"/>
            <ColumnDefinition Width="341*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Background="#4E342E">

            <Grid Margin="15">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Text="☕ Coffee Gold"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#D4AF37"/>

                    <TextBlock Text="Olá, Cliente!"
                               FontSize="16"
                               Foreground="White"/>

                </StackPanel>

                <Button Grid.Column="1"
                        Width="45"
                        Height="45"
                        FontSize="20"
                        Background="#D4AF37"
                        Foreground="White"
                        BorderBrush="Transparent"
                        Content="🛒"/>

            </Grid>

        </Border>

        <!-- Pesquisa -->
        <Border Grid.Row="1"
                Margin="15,10,15,10"
                Background="White"
                CornerRadius="20">

            <TextBox BorderThickness="0"
                     Background="Transparent"
                     FontSize="16"
                     VerticalContentAlignment="Center"
                     Margin="15,0"
                     Text="Pesquisar cafés..."/>

        </Border>

        <!-- Banner -->
        <Border Grid.Row="2"
                Margin="15,15,15,15"
                CornerRadius="20"
                Background="#6F4E37">

            <Grid>

                <StackPanel Margin="20">

                    <TextBlock Text="20% OFF"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FFD700"/>

                    <TextBlock Text="Nos cafés especiais"
                               FontSize="18"
                               Foreground="White"/>

                    <Button Content="Peça Agora"
                            Width="120"
                            Height="40"
                            Margin="0,20,0,0"
                            Background="#D4AF37"
                            Foreground="White"
                            BorderBrush="Transparent"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- Categorias -->
        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled">

            <StackPanel Orientation="Horizontal"
                        Margin="10">

                <Button Content="☕ Café"
                        Width="90"
                        Margin="5"
                        Background="#D4AF37"/>

                <Button Content="🍰 Doces"
                        Width="90"
                        Margin="5"
                        Background="#D4AF37"/>

                <Button Content="🥐 Salgados"
                        Width="100"
                        Margin="5"
                        Background="#D4AF37"/>

                <Button Content="🧋 Bebidas"
                        Width="100"
                        Margin="5"
                        Background="#D4AF37"/>

            </StackPanel>

        </ScrollViewer>

        <!-- Produtos -->
        <ScrollViewer Grid.Row="4" Margin="0,10,0,60" Grid.RowSpan="2">

            <WrapPanel HorizontalAlignment="Center">

                <!-- Produto 1 -->
                <Border Width="160"
                        Height="210"
                        Margin="10"
                        Background="White"
                        CornerRadius="15">

                    <StackPanel>

                        <TextBlock Text="☕"
                                   FontSize="60"
                                   HorizontalAlignment="Center"
                                   Margin="0,10"/>

                        <TextBlock Text="Latte"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="R$ 14,90"
                                   FontSize="18"
                                   Foreground="#8B4513"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Adicionar"
                                Width="110"
                                Margin="0,15"
                                HorizontalAlignment="Center"
                                Background="#D4AF37"
                                Foreground="White"/>

                    </StackPanel>

                </Border>

                <!-- Produto 2 -->
                <Border Width="160"
                        Height="210"
                        Margin="10"
                        Background="White"
                        CornerRadius="15">

                    <StackPanel>

                        <TextBlock Text="🍰"
                                   FontSize="60"
                                   HorizontalAlignment="Center"
                                   Margin="0,10"/>

                        <TextBlock Text="Brownie"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="R$ 12,00"
                                   FontSize="18"
                                   Foreground="#8B4513"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Adicionar"
                                Width="110"
                                Margin="0,15"
                                HorizontalAlignment="Center"
                                Background="#D4AF37"
                                Foreground="White"/>

                    </StackPanel>

                </Border>

                <!-- Produto 3 -->
                <Border Width="160"
                        Height="210"
                        Margin="10"
                        Background="White"
                        CornerRadius="15">

                    <StackPanel>

                        <TextBlock Text="🧋"
                                   FontSize="60"
                                   HorizontalAlignment="Center"
                                   Margin="0,10"/>

                        <TextBlock Text="Frapê"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="R$ 18,90"
                                   FontSize="18"
                                   Foreground="#8B4513"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Adicionar"
                                Width="110"
                                Margin="0,15"
                                HorizontalAlignment="Center"
                                Background="#D4AF37"
                                Foreground="White"/>

                    </StackPanel>

                </Border>

            </WrapPanel>

        </ScrollViewer>

        <!-- Menu inferior -->
        <Border Grid.Row="4"
                Background="#4E342E" Margin="0,334,0,0" Grid.RowSpan="2">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="🏠&#10;Início"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"/>

                <Button Grid.Column="1"
                        Content="❤️&#10;Favoritos"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"/>

                <Button Grid.Column="2"
                        Content="🛒&#10;Carrinho"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"/>

                <Button Grid.Column="3"
                        Content="👤&#10;Perfil"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"/>

            </Grid>

        </Border>

    </Grid>

</Window>