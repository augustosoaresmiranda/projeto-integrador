<Window x:Class="Cafeteria_projeto_integrador.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cafeteria_projeto_integrador"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF0C0C0C">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- MENU-->
        <StackPanel Background="#FF6A452C">

            <TextBlock
                       Foreground="White"
                       FontSize="22"
                       Margin="20" FontFamily="Script MT Bold"><Run Language="pt-br" Text="Saint Coffe"/></TextBlock>
            <Button Content="Home" Height="40"
                    Margin="10" Click="BtnHome_Click" FontFamily="Script MT Bold">
            </Button>

            <Button Content="Cadastrar ou editar Produtos" Height="40"
                    Margin="10" Click="BtnCadastroProduto_Click" Width="200" FontFamily="Script MT Bold" BorderBrush="#FFDB9C60" Foreground="#FFDB9C60"/>
            <Button Content="Produtos" Height="40"
                Click="BtnCadastroProduto_Click" Width="200" FontFamily="Script MT Bold"/>



        </StackPanel>
        <!--CONTEUDO-->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden" Foreground="Black"/>
        <Image Margin="31,30,31,0" Source="/ChatGPT Image 29 de mai. de 2026, 19_30_23.png" Stretch="Fill" Grid.Column="1"/>
        <Button Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="31,30,0,0" VerticalAlignment="Top" Height="75" Width="96">
            <Button.Background>
                <ImageBrush ImageSource="/Image8.png"/>
            </Button.Background>
        </Button>
        <Button Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="163,30,0,0" VerticalAlignment="Top" Height="75" Width="96">
            <Button.Background>
                <ImageBrush ImageSource="/black coffe.png"/>
            </Button.Background>
        </Button>
        <Button Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="290,30,0,0" VerticalAlignment="Top" Height="75" Width="96">
            <Button.Background>
                <ImageBrush ImageSource="/84a84dfd-14ed-4b15-8eed-ccb779057e33.png"/>
            </Button.Background>
        </Button>
        <Button Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="427,30,0,0" VerticalAlignment="Top" Height="75" Width="96">
            <Button.Background>
                <ImageBrush ImageSource="/moca branco.png"/>
            </Button.Background>
        </Button>
        <Button Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="31,142,0,0" VerticalAlignment="Top" Height="75" Width="96">
            <Button.Background>
                <ImageBrush ImageSource="/belga.png"/>
            </Button.Background>
        </Button>
        <Button Grid.Column="1" Content="Button" HorizontalAlignment="Left" Margin="163,142,0,0" VerticalAlignment="Top" Height="75" Width="96"/>
        <Button Grid.Column="1" Content="Button" HorizontalAlignment="Left" Margin="290,142,0,0" VerticalAlignment="Top" Height="75" Width="96"/>
        <Button Grid.Column="1" Content="Button" HorizontalAlignment="Left" Margin="427,142,0,0" VerticalAlignment="Top" Height="75" Width="96"/>
    </Grid>
</Window>
            


