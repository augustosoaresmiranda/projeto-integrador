<Page x:Class="Cafeteria_projeto_integrador.Cadastro"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Cafeteria_projeto_integrador"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Cadastro">

    <Canvas Background="#FF6F4E37">
        <Image Margin="0,-43,0,-43" Source="/ChatGPT Image 27 de mai. de 2026, 21_09_46.png" Stretch="Fill" HorizontalAlignment="Center" Opacity="0.2" Width="715"/>

        <Label Content="Nome" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFFFFBFB" Canvas.Left="250" Canvas.Top="88">
            <Label.BorderBrush>
                <ImageBrush/>
            </Label.BorderBrush>
        </Label>
        <Label Content="Senha" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.119,0.446" Background="White" Canvas.Left="250" Canvas.Top="168"/>
        <TextBox x:Name="txbnome" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Canvas.Left="320" Canvas.Top="92" />
        <PasswordBox x:Name="txbsenha" HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" Canvas.Left="320" Canvas.Top="168"/>
        <Button Content="Cadastrar" HorizontalAlignment="Center" Margin="0,277,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.135,0.589"/>


    </Canvas>
</Page>
