<Window x:Class="Cafeteria.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coffee Gold"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#2E1F1A">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <Border Background="#3B2A24">

            <StackPanel Margin="15">

                <TextBlock Text="☕"
                           FontSize="55"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="COFFEE GOLD"
                           Foreground="#D4AF37"
                           FontWeight="Bold"
                           FontSize="25"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <Button Content="🏠 Início"
                        Height="45"
                        Margin="0,5"
                        FontSize="16"
                        Background="#6F4E37"
                        Foreground="White"/>

                <Button Content="👤 Clientes"
                        Height="45"
                        Margin="0,5"
                        FontSize="16"
                        Background="#6F4E37"
                        Foreground="White"/>

                <Button Content="☕ Produtos"
                        Height="45"
                        Margin="0,5"
                        FontSize="16"
                        Background="#6F4E37"
                        Foreground="White"/>

                <Button Content="🛒 Pedidos"
                        Height="45"
                        Margin="0,5"
                        FontSize="16"
                        Background="#6F4E37"
                        Foreground="White"/>

                <Button Content="📊 Relatórios"
                        Height="45"
                        Margin="0,5"
                        FontSize="16"
                        Background="#6F4E37"
                        Foreground="White"/>

                <Button Content="🚪 Sair"
                        Height="45"
                        Margin="0,40,0,0"
                        Background="#8B0000"
                        Foreground="White"/>
            </StackPanel>

        </Border>

        <!-- CONTEÚDO -->
        <Grid Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Border Background="#D4AF37"
                    CornerRadius="15">

                <TextBlock Text="Bem-vindo ao Sistema da Cafeteria"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#3B2A24"
                           VerticalAlignment="Center"
                           Margin="20"/>
            </Border>

            <!-- Dashboard -->
            <WrapPanel Grid.Row="1"
                       Margin="0,20">

                <Border Width="220"
                        Height="140"
                        Margin="10"
                        CornerRadius="15"
                        Background="#6F4E37">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="👥"
                                   FontSize="45"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Clientes"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="125"
                                   FontSize="30"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <Border Width="220"
                        Height="140"
                        Margin="10"
                        CornerRadius="15"
                        Background="#6F4E37">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="☕"
                                   FontSize="45"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Produtos"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="48"
                                   FontSize="30"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <Border Width="220"
                        Height="140"
                        Margin="10"
                        CornerRadius="15"
                        Background="#6F4E37">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="🛒"
                                   FontSize="45"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Pedidos"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="78"
                                   FontSize="30"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <Border Width="220"
                        Height="140"
                        Margin="10"
                        CornerRadius="15"
                        Background="#6F4E37">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="💰"
                                   FontSize="45"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Faturamento"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="R$ 12.540"
                                   FontSize="26"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

            </WrapPanel>

        </Grid>

    </Grid>

</Window>